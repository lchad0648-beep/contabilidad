# Cadena de conexión a Postgres (Supabase). Usa la versión "pooled" (puerto 6543,
# Transaction mode) cuando despliegues en Vercel/serverless.
DATABASE_URL=postgres://postgres:PASSWORD@HOST:6543/postgres

# Credenciales del primer usuario admin (se crea solo la primera vez que arranca
# la app, si no existe ya un usuario con ese nombre).
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esta-contraseña
